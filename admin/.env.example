# URL of the running backend API.
# Use http://localhost:8080 when the browser and the backend run on the same
# machine. When accessing the admin from another device on the LAN, replace
# localhost with the host machine's LAN IP (e.g. http://192.168.1.x:8080).
# NEXT_PUBLIC_* variables are baked into the Next.js bundle at build time, so
# after changing this value you must run `npm run build` (or restart `npm run dev`).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
