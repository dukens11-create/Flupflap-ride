NODE_ENV=production
PORT=8080
LOG_LEVEL=warn
JWT_SECRET=replace-with-production-secret
ADMIN_SEED_PASSWORD=replace-with-production-admin-password
STRIPE_WEBHOOK_SECRET=replace-with-production-webhook-secret
DATA_STORE_MODE=file
DATA_STORE_FILE=.data/store.json
REDIS_URL=redis://production-redis:6379
