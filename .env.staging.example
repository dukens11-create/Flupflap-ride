NODE_ENV=production
PORT=8080
LOG_LEVEL=info
JWT_SECRET=replace-with-staging-secret
ADMIN_SEED_PASSWORD=replace-with-staging-admin-password
STRIPE_WEBHOOK_SECRET=replace-with-staging-webhook-secret
DATA_STORE_MODE=file
DATA_STORE_FILE=.data/store.json
REDIS_URL=redis://staging-redis:6379
MAPBOX_PUBLIC_TOKEN=
MAPBOX_STYLE_URL=mapbox://styles/mapbox/dark-v11
MAPBOX_SATELLITE_STYLE_URL=mapbox://styles/mapbox/satellite-streets-v12
